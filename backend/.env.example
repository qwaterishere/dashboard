DB_URL=sqlite:///dashboard.db
APP_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:8000
RATE_LIMIT=60/minute
RATE_LIMIT_ENABLED=true

HSTS_ENABLED=false

# Authentication
JWT_SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_COOKIE_SECURE=false
AUTH_ENABLED=true

SYNC_SCHEDULER_TOKEN=your-long-random-secret-at-least-16-chars