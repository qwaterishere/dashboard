DB_URL=sqlite:///dashboard.db
APP_ENV=development
CORS_ORIGINS=http://localhost:4200,http://localhost:8000
RATE_LIMIT=60/minute
RATE_LIMIT_ENABLED=true

# HSTS выключен локально (в production включается автоматически при APP_ENV=production)
HSTS_ENABLED=false

# JWT — в production задайте уникальный секрет (openssl rand -hex 32)
JWT_SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_COOKIE_SECURE=false
AUTH_ENABLED=true

# Шифрование iiko-паролей в БД (production: openssl rand -hex 32)
# CREDENTIALS_ENCRYPTION_KEY=<openssl rand -hex 32>

# Fallback для CLI/аудита без UI (optional; предпочтительно — настройки пользователя)
IIKO_URL=https://example.iiko.it:443
IIKO_LOGIN=api_user
IIKO_PASSWORD=changeme
# Suffix-allowlist исходящих подключений к iiko (через запятую; по умолчанию .iiko.it)
IIKO_URL_ALLOWED_SUFFIXES=.iiko.it

# --- Production profile (пример, не для локального .env) ---
# APP_ENV=production
# DB_URL=postgresql+psycopg://user:pass@localhost:5432/dashboard
# JWT_SECRET_KEY=<openssl rand -hex 32>
# JWT_COOKIE_SECURE=true
# HSTS_ENABLED=true
# CORS_ORIGINS=https://dashboard.example.com
