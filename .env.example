# CORS origins (comma-separated). Dev defaults cover ng serve + uvicorn.
CORS_ORIGINS=http://localhost:4200,http://localhost:8000

# Rate limiting on /api/* (slowapi format)
RATE_LIMIT=60/minute
RATE_LIMIT_ENABLED=true

# Static files root. Use frontend/dist after production cutover (Phase 8).
# STATIC_DIR=frontend/dist
